PORT=8787
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:8787

# LINE Login / LIFF
DRAFT_EVENT_NAME=エイト・ドラフト
LINE_ASSISTANT_NAME=ドラフト進行役
GUIDE_MEMBER_ID=m-guide
LINE_LIFF_ID=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_BOT_USER_ID=
LINE_DRAFT_GROUP_NAME=
LINE_DRAFT_GROUP_ID=
# Legacy compatibility while the old server variable names are phased out.
LINE_WC_GROUP_NAME=
LINE_WC_GROUP_ID=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Firebase legacy bridge for existing memberProfiles, optional
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Yahoo Developer, optional content discovery bridge
YAHOO_APP_ID=

# Gemini, optional LINE mention Q&A.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# football-data.org: auto-fetch World Cup results (free tier covers WC).
FOOTBALL_DATA_TOKEN=
# Optional: protect POST /api/sync-results. Internal poller runs regardless.
SYNC_KEY=
# Optional: override auto-sync interval in ms. Default 300000 (5 min).
SYNC_INTERVAL_MS=
